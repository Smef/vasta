{
  "name": "vasta-orm",
  "version": "0.0.10",
  "description": "Active record ORM built on top of Kysely",
  "type": "module",
  "author": "David Nahodyl <david.nahodyl@gmail.com>",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Smef/vasta.git"
  },
  "bugs": {
    "url": "https://github.com/Smef/vasta/issues"
  },
  "homepage": "https://vastajs.com/",
  "keywords": [
    "orm",
    "kysely",
    "typescript",
    "active record"
  ],
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/cjs/index.js"
    }
  },
  "scripts": {
    "dev": "tsc --watch",
    "dev:docs": "cd docs && pnpm run dev",
    "test": "vitest run --typecheck",
    "test:reset": "pnpm run db:reset && vitest run",
    "test:watch": "vitest --typecheck",
    "clean": "rm -rf dist/*",
    "build": "pnpm run clean && (npm run build:esm & npm run build:cjs)",
    "build:esm": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json --resolve-full-paths --resolve-full-extension .js",
    "build:cjs": "tsc -p tsconfig.cjs.json && tsc-alias -p tsconfig.cjs.json",
    "generate:docs": "cd docs && pnpm run generate",
    "db:reset": "kysely migrate:rollback --all && kysely migrate:latest && kysely seed:run",
    "db:migrate": "kysely migrate:latest",
    "db:seed": "kysely seed:run"
  },
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.18.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "kysely": "^0.28.12",
    "kysely-ctl": "^0.20.0",
    "pg": "^8.20.0",
    "prettier": "^3.8.1",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^1.6.1"
  },
  "peerDependencies": {
    "kysely": "^0.28.11"
  },
  "resolutions": {
    "unimport": "5.6.0",
    "citty": "0.1.6"
  }
}
