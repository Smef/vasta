{
  "compilerOptions": {
    "moduleResolution": "Node",
    "target": "ESNext",
    "declaration": true,
    "strict": true,
    "noImplicitAny": true,
    "module": "ESNext",
    "outDir": "dist/esm",
    "baseUrl": ".",
    "paths": {
      "@src/*": ["./src/*"],
      "@test/*": ["./test/*"]
    }
  },
  "include": ["src/**/*", "docs/**/*"],
  "forceConsistentCasingInFileNames": true
}
